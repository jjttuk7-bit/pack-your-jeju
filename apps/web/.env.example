# Pack Your Jeju frontend 환경변수
# Vercel · 로컬 개발 공용. VITE_ 접두사가 붙은 것만 브라우저에서 접근 가능.
#
# 프로덕션(Vercel 배포)에는 Railway URL 세팅:
#   VITE_API_BASE_URL=https://pack-your-jeju-production.up.railway.app
# 로컬 개발: 아래 기본값(로컬 uvicorn). 미설정 시 api.ts가 localhost:8000 폴백.
VITE_API_BASE_URL=http://localhost:8000

# 선택: 네이버 지도 JavaScript API Client ID.
# Vercel 프론트 빌드 환경변수에 넣고, 네이버 클라우드 콘솔에서 배포 도메인을 허용해야 합니다.
VITE_NAVER_MAP_CLIENT_ID=
