# Pack Your Jeju 환경변수 (CLAUDE.md 절대 규칙 5·6)
#
# gpt-5.3-mini 고정. LLM_MODEL 같은 스왑 변수는 만들지 않는다.
# OPENAI_API_KEY 미설정 시 조립 문구는 템플릿, 판정은 규칙 기반 폴백으로 동작해야 한다.
#
# 이 파일을 복사해 .env 로 만들고 실제 키를 채우세요:
#   cp .env.example .env

OPENAI_API_KEY=
VISITJEJU_API_KEY=
KMA_SERVICE_KEY=

# 서버 전용 Naver Directions 인증. VITE_ 접두사를 붙이거나 프런트 번들에 노출하지 않습니다.
NAVER_DIRECTIONS_CLIENT_ID=
NAVER_DIRECTIONS_CLIENT_SECRET=

# 로컬 5432가 다른 컨테이너에 잡혀 5433으로 노출됩니다 (docker-compose.yml 참고).
DATABASE_URL=postgresql+psycopg://jeju:jeju@localhost:5433/jeju

# Supabase Auth/Storage — SUPABASE_SERVICE_ROLE_KEY is server-only.
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EVIDENCE_BUCKET=travel-evidence
